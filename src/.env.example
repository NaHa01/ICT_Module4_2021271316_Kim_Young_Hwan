# 백엔드 환경 변수 예시 - 실제 값으로 채운 뒤 .env 로 복사하세요.
# 모든 외부 키는 선택 사항입니다(없으면 Yahoo/Frankfurter/mock 으로 폴백).
PORT=4000

# ── 한국투자증권(KIS) 오픈 API — 키 A ──
# 7개 지표(환율·국내외 지수) 현재가의 주력 소스입니다.
# 키가 없거나 호출이 실패하면 키움/Yahoo/Frankfurter → mock 으로 폴백합니다.
KIS_APP_KEY=발급받은_APP_KEY
KIS_APP_SECRET=발급받은_APP_SECRET
# true=모의투자 도메인(openapivts:29443), false=실전투자 도메인(openapi:9443)
# 실전(false)은 "실전투자 계좌"로 발급한 KIS_APP_KEY/SECRET 이어야 합니다.
KIS_MOCK_TRADE=false

# ── 한국투자증권(KIS) 오픈 API — 키 B (선택, 권장) ──
# KIS 거래제한(EGW00201)은 공식 한도(appkey당 실전 20콜/초) 이하인 총 5콜/초에서도 발생했고,
# 실측 결과 "TR(엔드포인트)별 ~2콜/초 제한"으로 추정됩니다(공식 문서에 없는 실측 기반 가설).
# 7개가 해외(FHKST03030100)·국내(FHPUP02100000) 2개 TR에 몰리므로 한 키로는 초과합니다.
# 2번째 실전 키로 키 A/B의 TR당 호출을 ≤2콜/초로 낮추자 EGW 0회로 검증됐습니다.
#   키 A = usdkrw · eurkrw · kospi,  키 B = kosdaq · kospi200 · sp500 · nasdaq
# 비워두면 1키 모드(키 A가 7개 전부 담당, EGW 발생 가능)로 자동 폴백합니다.
KIS_APP_KEY2=
KIS_APP_SECRET2=
# 미설정 시 KIS_MOCK_TRADE 따라감(실전이면 false).
KIS_MOCK_TRADE2=false

# ── 키움증권 REST API (선택, 국내지수 백업) ──
# KOSPI/KOSDAQ/KOSPI200 현재가의 백업 소스입니다(KIS 국내지수가 실패할 때만 호출).
# 키가 없거나 실패하면 다른 KIS 키 → Yahoo → mock 으로 폴백합니다.
KIWOOM_APP_KEY=발급받은_APP_KEY
KIWOOM_APP_SECRET=발급받은_SECRET_KEY
# true=모의투자 도메인(mockapi.kiwoom.com), false=실전투자 도메인(api.kiwoom.com)
KIWOOM_MOCK_TRADE=true

# ── 페이싱 ──
# 모든 외부 호출 사이 최소 간격 하한(ms). 키별 페이싱(1000÷담당지표수)의 하한으로 적용.
INDICATOR_GAP_MS=140

# ── 네이버 검색(뉴스) 오픈 API (선택) ──
# 비워두면 newsService 가 mock 뉴스로 폴백합니다.
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ── 페일오버 / 시뮬레이션 타이밍 (ms) ──
MAIN_TIMEOUT_MS=1000
INJECTED_DELAY_MS=3000
AUTO_RECOVERY_MS=5000
